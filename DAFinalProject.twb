      <aliases enabled='yes' />
      <column caption='Is Weekend' datatype='string' name='[Calculation_0245253485707265]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;weekday&apos;, [check_in_date]) = 1 OR DATEPART(&apos;weekday&apos;, [check_in_date]) = 7 &#13;&#10;THEN &quot;Weekend&quot; &#13;&#10;ELSE &quot;Weekday&quot; &#13;&#10;END' />
      </column>
      <column caption='COA%' datatype='real' default-format='p0.00%' name='[Calculation_0245253485846530]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([commission_amount]) / SUM([gross_room_revenue])' />
      </column>
      <column caption='Net ADR' datatype='real' name='[Calculation_0245253486759939]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_room_revenue]) / COUNT([booking_id])' />
      </column>
      <column caption='Net ADR Performance' datatype='string' name='[Calculation_0245253492404228]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0245253486759939] &lt; 123.87 &#13;&#10;THEN &quot;Underperforming&quot; &#13;&#10;ELSE &quot;High Performing&quot; &#13;&#10;END' />
