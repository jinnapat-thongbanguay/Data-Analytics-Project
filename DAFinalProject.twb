      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([booking_id]) / TOTAL(COUNT([booking_id]))'>
          <table-calc ordering-field='[federated.13sdkzc1ipwagj19q19td0ollu3i].[Calculation_1758044386238465]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='NetADR' datatype='real' name='[Calculation_0755770637725696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_room_revenue]) / COUNTD([booking_id])' />
      </column>
      <column caption='Volume' datatype='integer' name='[Calculation_0755770645434369]' role='measure' type='quantitative'>
