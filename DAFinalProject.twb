      </column>
      <column caption='Is Weekend' datatype='string' name='[Calculation_1758044386238465]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATENAME(&quot;weekday&quot;, [check_in_date]) = &quot;Saturday&quot; &#10;OR DATENAME(&quot;weekday&quot;, [check_in_date]) = &quot;Sunday&quot; &#10;THEN &quot;Weekend&quot; &#10;ELSE &quot;Weekday&quot; &#10;END' />
      </column>
      <column caption='GrossADR' datatype='real' name='[Calculation_1758044386885634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([gross_room_revenue]) / COUNTD([booking_id])' />
      </column>
      <column caption='Net RevPAR' datatype='real' name='[Calculation_1758044402810883]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_room_revenue]) / 150  // 150 = Total Rooms Available' />
